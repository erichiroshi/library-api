<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Conversores e propriedades do Spring Boot -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

	<!-- Resolve propriedade do Spring Environment corretamente -->
    <springProperty scope="context"
                    name="appName"
                    source="spring.application.name"
                    defaultValue="library"/>

    <!-- ─────────────────────────────────────────────────────────────
         Padrão com traceId e spanId (preenchidos pelo Micrometer Tracing)
         Formato: DATA HORA  LEVEL [appName,traceId,spanId] thread logger - mensagem
         Quando não há trace ativo (ex: jobs agendados), exibe zeros.
         ───────────────────────────────────────────────────────────── -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %5level [${appName},%X{traceId:- },%X{spanId:- }] [%thread] %-40.40logger{39} : %msg%n"/>

    <!-- Appender de console -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Appender de arquivo — ativo apenas nos profiles prod -->
    <springProfile name="prod">
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/application.log</file>
            
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>logs/application.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <maxFileSize>10MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>1GB</totalSizeCap>
            </rollingPolicy>
            
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>
    </springProfile>

    <!-- ─────────────────────────────────────────────────────────────
         Níveis por profile
         ───────────────────────────────────────────────────────────── -->
    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.example.library" level="DEBUG"/>
        <logger name="org.hibernate.SQL" level="DEBUG"/>
    </springProfile>

    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
        <logger name="com.example.library" level="INFO"/>
        <logger name="org.springframework.web" level="WARN"/>
        <logger name="org.hibernate" level="WARN"/>
    </springProfile>

    <!-- Fallback para outros profiles (test, it) -->
    <springProfile name="!dev &amp; !prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.example.library" level="DEBUG"/>
    </springProfile>

</configuration>